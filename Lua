        Effect = "CreatingServer"
    })
end

--[[
    ═══════════════════════════════
      UNRELIABLE REMOTE (Movement)
    ═══════════════════════════════
]]

local UnreliableRemote = ReplicatedStorage:WaitForChild("UnreliableRemoteEvent", 10)
local seqCounter = 0

local function GetNextSeq()
    seqCounter += 1
    return seqCounter
end

local function FireCustomMoveStun()
    if not UnreliableRemote then return end

    local root = GetRoot()
    local hum = GetHumanoid()
    if not root or not hum then return end

    local velY = root.AssemblyLinearVelocity.Y
    local isFalling = velY < -1
    local isRunning = hum.MoveDirection.Magnitude > 0.1

    UnreliableRemote:FireServer({
        falling = isFalling,
        velY = velY,
        clientT = os.clock(),
        holdingSpace = false,
        cframe = root.CFrame,
        seq = GetNextSeq(),
        running = isRunning
    }, "CustomMoveStun")
end

