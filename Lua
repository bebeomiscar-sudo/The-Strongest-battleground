-- // Combo Sequence
local ComboSequence = {
    {fn = FireLeftClick,  delay = 0.15},
    {fn = FireLeftClick,  delay = 0.15},
    {fn = FireLeftClick,  delay = 0.15},
    {fn = FireRightClick, delay = 0.20},
    {fn = FireHit,        delay = 0.10},
}

local function RunCombo(targetCFrame)
    for _, step in ipairs(ComboSequence) do
        if not Flags.AutoCombo then break end
        step.fn(targetCFrame)
        task.wait(Flags.ComboDelay)
    end
end

-- // Skill Keys
local SkillKeys = {"q", "e", "r", "f"}

