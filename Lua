local ReplicationRemote = ReplicatedStorage:WaitForChild("Replication", 10)

-- // Velocity Forward
local function FireVelocityForward(distance)
    if not ReplicationRemote then return end
    firesignal(ReplicationRemote.OnClientEvent, {
        Distance = distance or Flags.VelocityDist,
        Effect = "Velocity Forward"
    })
end

-- // Notification
local function FireNotification(char, message, button)
    if not ReplicationRemote then return end
    firesignal(ReplicationRemote.OnClientEvent, {
        char = char or "Hunter",
        Message = message or "",
        Button = button or "Reset",
        Effect = "Notification"
    })
end

-- // Custom Server Teleporting
local function FireCustomServerTeleporting()
    if not ReplicationRemote then return end
    firesignal(ReplicationRemote.OnClientEvent, {
        Effect = "CustomServerTeleporting"
    })
end

-- // Creating Server
local function FireCreatingServer()
    if not ReplicationRemote then return end
