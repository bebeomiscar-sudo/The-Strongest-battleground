-- // Master Loop
RunService.Heartbeat:Connect(function()
    if not IsAlive() then return end

    local target, dist = GetNearestEnemy(Flags.AttackRange)

    -- Auto Combo
    if Flags.AutoCombo and target and dist <= Flags.AttackRange then
        task.spawn(function()
            RunCombo(target.CFrame)
        end)
    end

    -- Kill Aura (Rapid Left Clicks)
    if Flags.KillAura and target and dist <= Flags.AttackRange then
        FireLeftClick(target.CFrame)
    end

    -- Auto Velocity
    if Flags.AutoVelocity and target and dist <= 50 then
        FireVelocityForward(Flags.VelocityDist)
    end

    -- CustomMoveStun
    FireCustomMoveStun()
end)

-- // Auto Skill Loop
task.spawn(function()
    while true do
        task.wait(Flags.SkillDelay)
        if not IsAlive() then continue end
        if not Flags.AutoSkill then continue end

        local target, dist = GetNearestEnemy(40)
        if not target then continue end

        for _, key in ipairs(SkillKeys) do
            if not Flags.AutoSkill then break end
            FireKeyPress(key, target.CFrame)
            task.wait(0.2)
        end
    end
end)

-- // Speed Loop
task.spawn(function()
    while true do
        task.wait(0.1)
        if not IsAlive() then continue end
        if not Flags.SpeedEnabled then continue end

        local hum = GetHumanoid()
        if hum then
            hum.WalkSpeed = Flags.SpeedValue
        end
    end
end)

